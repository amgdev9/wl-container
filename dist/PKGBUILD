pkgname=wl-container
pkgver=1.0.0
pkgrel=1
pkgdesc='Create Wayland socket for containers via wp_security_context_manager_v1'
arch=('x86_64' 'aarch64')
url='https://github.com/amgdev9/wl-container'
license=('MIT')
depends=('wayland')
makedepends=('cargo' 'clang' 'wayland-protocols')
source=("$pkgname-main.tar.gz::https://github.com/amgdev9/wl-container/archive/main.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$srcdir/$pkgname-main"
  cargo build --release
}

package() {
  cd "$srcdir/$pkgname-main"
  install -Dm755 target/release/wl-container "$pkgdir/usr/bin/wl-container"
}
